# secrets — NEVER commit
# (an inline '#' is NOT a comment in .gitignore, so the note goes on its own line)
# bridge/config.json holds the bearer token
bridge/config.json
.env
*.key
*.pem

# python
__pycache__/
*.pyc
.venv/
venv/

# generated Xcode project (regenerate with `xcodegen generate`)
watch-app/ClaudeWatch.xcodeproj/
watch-app/*.xcworkspace/
build/
DerivedData/

# os / editor
.DS_Store
*.swp
.idea/
.vscode/
